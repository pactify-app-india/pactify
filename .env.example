# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Auth0
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id
VITE_AUTH0_AUDIENCE=https://api.yourapp.com
VITE_ROLE_CLAIM_NAMESPACE=https://yourapp.com
VITE_API_BASE_URL=http://localhost:3001

# Backend (server/.env only — never commit real values)
# APP_BASE_URL=http://localhost:5173
# REDIRECT_SECRET=generate_locally_never_share
# ROLE_CLAIM_NAMESPACE=https://yourapp.com
# PORT=3001
